FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

RUN pip install --no-cache-dir uv

COPY apps/jobspy_worker/pyproject.toml ./pyproject.toml
RUN uv sync --no-dev

COPY apps/jobspy_worker ./apps/jobspy_worker

EXPOSE 8010

CMD ["uv", "run", "uvicorn", "apps.jobspy_worker.main:app", "--host", "0.0.0.0", "--port", "8010"]
